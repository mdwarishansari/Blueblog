{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",

    "lib": ["ES2020"],
    "types": ["node"],

    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,

    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,

    "sourceMap": true
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
