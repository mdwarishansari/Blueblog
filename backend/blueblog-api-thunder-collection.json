      "body": "{\n  \"title\": \"My First Blog Post\",\n  \"excerpt\": \"This is a brief summary of my first blog post\",\n  \"content\": {\n    \"type\": \"doc\",\n    \"content\": [\n      {\n        \"type\": \"paragraph\",\n        \"content\": [\n          {\n            \"type\": \"text\",\n            \"text\": \"This is the content of my first blog post created via API.\"\n          }\n        ]\n      }\n    ]\n  },\n  \"categoryIds\": [],\n  \"status\": \"DRAFT\",\n  \"seoTitle\": \"My First Blog Post - SEO Title\",\n  \"seoDescription\": \"This is the SEO description for my first blog post\",\n  \"canonicalUrl\": \"https://myblog.com/first-post\"\n}",
      "bodyType": "json",
      "tests": [
        {
          "id": "create-post-tests",
          "script": "const body = await client.res.getBody();\nconst jsonBody = JSON.parse(body);\n\nclient.test('Post created successfully', () => {\n  client.assert(res.status === 201, `Expected 201 but got ${res.status}`);\n  client.assert(jsonBody.success === true, 'Success should be true');\n  client.assert(jsonBody.data.id, 'Should return post ID');\n  client.assert(jsonBody.data.slug, 'Should return post slug');\n});\n\n// Store post ID for later use\nif (jsonBody.data.id) {\n  client.env.set('POST_ID', jsonBody.data.id);\n  client.env.set('POST_SLUG', jsonBody.data.slug);\n}"
        }
      ]
    },
