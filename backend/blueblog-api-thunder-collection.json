          "script": "const body = await client.res.getBody();\nconst jsonBody = JSON.parse(body);\n\nclient.test('Login successful', () => {\n  client.assert(res.status === 200, `Expected 200 but got ${res.status}`);\n  client.assert(jsonBody.success === true, 'Success should be true');\n  client.assert(jsonBody.data.user.email === 'admin@blueblog.com', 'Should return admin user');\n});\n\n// Store user ID for later use\nif (jsonBody.data.user.id) {\n  client.env.set('USER_ID', jsonBody.data.user.id);\n  client.env.set('USER_ROLE', jsonBody.data.user.role);\n}"
        }
