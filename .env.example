# =========================================
# BlueBlog — Environment Variables (Example)
# =========================================
# Copy this file to `.env.local` for development
# Never commit real secrets to GitHub
# =========================================


# -----------------------------------------
# Database
# -----------------------------------------
# LOCAL DEVELOPMENT (PostgreSQL)
DATABASE_URL="postgresql://bloguser:password@localhost:5432/blogdb?schema=public"

# PRODUCTION (Neon - pooled URL for Vercel)
# DATABASE_URL="postgresql://neondb_owner:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# DIRECT Neon URL (CLI / Prisma only — NOT for Vercel runtime)
# postgresql://neondb_owner:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require


# -----------------------------------------
# JWT Authentication
# -----------------------------------------
JWT_ACCESS_SECRET="replace_with_strong_random_secret"
JWT_REFRESH_SECRET="replace_with_strong_random_secret"

ACCESS_TOKEN_EXPIRES_IN="1d"
REFRESH_TOKEN_EXPIRES_IN="7d"


# -----------------------------------------
# Cloudinary (Image Uploads)
# -----------------------------------------
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"


# -----------------------------------------
# Rate Limiting
# -----------------------------------------
RATE_LIMIT_WINDOW_MS="900000"     # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"


# -----------------------------------------
# Admin Default Account (Seed Only)
# -----------------------------------------
ADMIN_EMAIL="admin@blog.com"
ADMIN_PASSWORD="Admin@123"
ADMIN_NAME="Blog Administrator"


# -----------------------------------------
# CORS
# -----------------------------------------
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:4000"


# -----------------------------------------
# Public Site Configuration (Safe to expose)
# -----------------------------------------
NEXT_PUBLIC_SITE_NAME="BlueBlog"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_DESCRIPTION="A modern, SEO-optimized blogging platform"


# -----------------------------------------
# SEO Defaults
# -----------------------------------------
NEXT_PUBLIC_DEFAULT_OG_IMAGE="/og-default.png"
NEXT_PUBLIC_TWITTER_HANDLE="@techblog"


# -----------------------------------------
# Admin Panel
# -----------------------------------------
NEXT_PUBLIC_ADMIN_PATH="/admin"
